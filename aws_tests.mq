# =========================================================================
# Lambda Tests
# =========================================================================

| let lambda_list_functions_json = "{\"Functions\":[{\"FunctionName\":\"process-orders\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:process-orders\",\"Runtime\":\"python3.11\",\"Handler\":\"lambda_function.lambda_handler\",\"CodeSize\":2048,\"Description\":\"Process incoming orders\",\"Timeout\":30,\"MemorySize\":128,\"LastModified\":\"2024-06-01T00:00:00Z\",\"State\":\"Active\"},{\"FunctionName\":\"send-notifications\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:send-notifications\",\"Runtime\":\"nodejs20.x\",\"Handler\":\"index.handler\",\"CodeSize\":4096,\"Description\":\"Send email notifications\",\"Timeout\":60,\"MemorySize\":256,\"LastModified\":\"2024-06-02T00:00:00Z\",\"State\":\"Active\"},{\"FunctionName\":\"generate-reports\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:generate-reports\",\"Runtime\":\"python3.11\",\"Handler\":\"reports.generate\",\"CodeSize\":8192,\"Description\":\"Generate monthly reports\",\"Timeout\":300,\"MemorySize\":512,\"LastModified\":\"2024-06-03T00:00:00Z\",\"State\":\"Inactive\"}]}" |

def test_lambda_functions_count():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::functions(response)
  | assert_eq(len(result), 3)
end

def test_lambda_function_names():
  let response = json::json_parse(lambda_list_functions_json)
  | let names = aws::lambda::function_names(response)
  | assert_eq(names, ["process-orders", "send-notifications", "generate-reports"])
end

def test_lambda_by_runtime_python():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "python3.11")
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["FunctionName"], "process-orders")
  | assert_eq(result[1]["FunctionName"], "generate-reports")
end

def test_lambda_by_runtime_node():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "nodejs20.x")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["FunctionName"], "send-notifications")
end

def test_lambda_by_runtime_none():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "ruby3.2")
  | assert_empty(result)
end

def test_lambda_by_state_active():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_state(response, "Active")
  | assert_eq(len(result), 2)
end

def test_lambda_by_state_inactive():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_state(response, "Inactive")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["FunctionName"], "generate-reports")
end

def test_lambda_total_memory():
  let response = json::json_parse(lambda_list_functions_json)
  | let total = aws::lambda::total_memory(response)
  | assert_eq(total, 896)
end

def test_lambda_total_memory_empty():
  let response = json::json_parse("{\"Functions\":[]}")
  | let total = aws::lambda::total_memory(response)
  | assert_eq(total, 0)
end

def test_lambda_functions_empty():
  let response = json::json_parse("{\"Functions\":[]}")
  | let result = aws::lambda::functions(response)
  | assert_empty(result)
end

def test_lambda_functions_to_markdown_table():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::functions_to_markdown_table(response)
  | assert(contains(result, "| FunctionName | Runtime | Handler | MemorySize | Timeout | State |"))
  | assert(contains(result, "process-orders"))
  | assert(contains(result, "python3.11"))
  | assert(contains(result, "lambda_function.lambda_handler"))
  | assert(contains(result, "128"))
  | assert(contains(result, "Active"))
end

def test_lambda_functions_to_markdown_table_empty():
  let response = json::json_parse("{\"Functions\":[]}")
  | let result = aws::lambda::functions_to_markdown_table(response)
  | assert_eq(result, "No functions found.")
end

# =========================================================================
# RDS Tests
# =========================================================================

| let rds_describe_db_instances_json = "{\"DBInstances\":[{\"DBInstanceIdentifier\":\"prod-mysql\",\"DBInstanceClass\":\"db.t3.medium\",\"Engine\":\"mysql\",\"EngineVersion\":\"8.0.33\",\"DBInstanceStatus\":\"available\",\"MultiAZ\":true,\"AllocatedStorage\":100},{\"DBInstanceIdentifier\":\"dev-postgres\",\"DBInstanceClass\":\"db.t3.micro\",\"Engine\":\"postgres\",\"EngineVersion\":\"15.4\",\"DBInstanceStatus\":\"available\",\"MultiAZ\":false,\"AllocatedStorage\":20},{\"DBInstanceIdentifier\":\"old-mysql\",\"DBInstanceClass\":\"db.t3.small\",\"Engine\":\"mysql\",\"EngineVersion\":\"5.7.43\",\"DBInstanceStatus\":\"stopped\",\"MultiAZ\":false,\"AllocatedStorage\":50}]}" |

def test_rds_db_instances_count():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::db_instances(response)
  | assert_eq(len(result), 3)
end

def test_rds_instance_ids():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let ids = aws::rds::instance_ids(response)
  | assert_eq(ids, ["prod-mysql", "dev-postgres", "old-mysql"])
end

def test_rds_available_instances():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::available_instances(response)
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["DBInstanceIdentifier"], "prod-mysql")
  | assert_eq(result[1]["DBInstanceIdentifier"], "dev-postgres")
end

def test_rds_by_engine_mysql():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::by_engine(response, "mysql")
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["DBInstanceIdentifier"], "prod-mysql")
  | assert_eq(result[1]["DBInstanceIdentifier"], "old-mysql")
end

def test_rds_by_engine_postgres():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::by_engine(response, "postgres")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["DBInstanceIdentifier"], "dev-postgres")
end

def test_rds_by_engine_none():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::by_engine(response, "aurora")
  | assert_empty(result)
end

def test_rds_db_instances_empty():
  let response = json::json_parse("{\"DBInstances\":[]}")
  | let result = aws::rds::db_instances(response)
  | assert_empty(result)
end

def test_rds_db_instances_to_markdown_table():
  let response = json::json_parse(rds_describe_db_instances_json)
  | let result = aws::rds::db_instances_to_markdown_table(response)
  | assert(contains(result, "| DBInstanceIdentifier | DBInstanceClass | Engine | EngineVersion | Status | MultiAZ |"))
  | assert(contains(result, "prod-mysql"))
  | assert(contains(result, "db.t3.medium"))
  | assert(contains(result, "mysql"))
  | assert(contains(result, "8.0.33"))
  | assert(contains(result, "available"))
  | assert(contains(result, "true"))
end

def test_rds_db_instances_to_markdown_table_empty():
  let response = json::json_parse("{\"DBInstances\":[]}")
  | let result = aws::rds::db_instances_to_markdown_table(response)
  | assert_eq(result, "No DB instances found.")
end

# =========================================================================
# CloudFormation Tests
# =========================================================================

| let cfn_describe_stacks_json = "{\"Stacks\":[{\"StackId\":\"arn:aws:cloudformation:us-east-1:123456789012:stack/prod-stack/001\",\"StackName\":\"prod-stack\",\"StackStatus\":\"CREATE_COMPLETE\",\"CreationTime\":\"2024-01-01T00:00:00Z\",\"Parameters\":[{\"ParameterKey\":\"Env\",\"ParameterValue\":\"prod\"},{\"ParameterKey\":\"Region\",\"ParameterValue\":\"us-east-1\"}],\"Outputs\":[{\"OutputKey\":\"VpcId\",\"OutputValue\":\"vpc-001\",\"Description\":\"Main VPC ID\"},{\"OutputKey\":\"SubnetIds\",\"OutputValue\":\"subnet-001,subnet-002\",\"Description\":\"Subnet IDs\"}]},{\"StackId\":\"arn:aws:cloudformation:us-east-1:123456789012:stack/dev-stack/002\",\"StackName\":\"dev-stack\",\"StackStatus\":\"UPDATE_COMPLETE\",\"CreationTime\":\"2024-02-01T00:00:00Z\",\"Parameters\":[{\"ParameterKey\":\"Env\",\"ParameterValue\":\"dev\"}],\"Outputs\":[{\"OutputKey\":\"VpcId\",\"OutputValue\":\"vpc-002\",\"Description\":\"Dev VPC ID\"}]},{\"StackId\":\"arn:aws:cloudformation:us-east-1:123456789012:stack/old-stack/003\",\"StackName\":\"old-stack\",\"StackStatus\":\"DELETE_FAILED\",\"CreationTime\":\"2023-01-01T00:00:00Z\",\"Parameters\":[],\"Outputs\":[]}]}" |

def test_cfn_stacks_count():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let result = aws::cloudformation::stacks(response)
  | assert_eq(len(result), 3)
end

def test_cfn_stack_names():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let names = aws::cloudformation::stack_names(response)
  | assert_eq(names, ["prod-stack", "dev-stack", "old-stack"])
end

def test_cfn_by_status_create_complete():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let result = aws::cloudformation::by_status(response, "CREATE_COMPLETE")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["StackName"], "prod-stack")
end

def test_cfn_by_status_update_complete():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let result = aws::cloudformation::by_status(response, "UPDATE_COMPLETE")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["StackName"], "dev-stack")
end

def test_cfn_by_status_none():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let result = aws::cloudformation::by_status(response, "ROLLBACK_COMPLETE")
  | assert_empty(result)
end

def test_cfn_stack_outputs():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let outputs = aws::cloudformation::stack_outputs(prod)
  | assert_eq(len(outputs), 2)
  | assert_eq(outputs[0]["OutputKey"], "VpcId")
  | assert_eq(outputs[0]["OutputValue"], "vpc-001")
end

def test_cfn_stack_outputs_empty():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let old_stack = all_stacks[2]
  | let outputs = aws::cloudformation::stack_outputs(old_stack)
  | assert_empty(outputs)
end

def test_cfn_stack_parameters():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let params = aws::cloudformation::stack_parameters(prod)
  | assert_eq(len(params), 2)
  | assert_eq(params[0]["ParameterKey"], "Env")
  | assert_eq(params[0]["ParameterValue"], "prod")
end

def test_cfn_output_value():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let value = aws::cloudformation::output_value(prod, "VpcId")
  | assert_eq(value, "vpc-001")
end

def test_cfn_output_value_not_found():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let value = aws::cloudformation::output_value(prod, "NonExistent")
  | assert_none(value)
end

def test_cfn_parameter_value():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let value = aws::cloudformation::parameter_value(prod, "Env")
  | assert_eq(value, "prod")
end

def test_cfn_parameter_value_not_found():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let all_stacks = aws::cloudformation::stacks(response)
  | let prod = all_stacks[0]
  | let value = aws::cloudformation::parameter_value(prod, "Unknown")
  | assert_none(value)
end

def test_cfn_stacks_empty():
  let response = json::json_parse("{\"Stacks\":[]}")
  | let result = aws::cloudformation::stacks(response)
  | assert_empty(result)
end

def test_cfn_stacks_to_markdown_table():
  let response = json::json_parse(cfn_describe_stacks_json)
  | let result = aws::cloudformation::stacks_to_markdown_table(response)
  | assert(contains(result, "| StackName | StackStatus | CreationTime |"))
  | assert(contains(result, "prod-stack"))
  | assert(contains(result, "CREATE_COMPLETE"))
  | assert(contains(result, "dev-stack"))
  | assert(contains(result, "UPDATE_COMPLETE"))
  | assert(contains(result, "old-stack"))
  | assert(contains(result, "DELETE_FAILED"))
end

def test_cfn_stacks_to_markdown_table_empty():
  let response = json::json_parse("{\"Stacks\":[]}")
  | let result = aws::cloudformation::stacks_to_markdown_table(response)
  | assert_eq(result, "No stacks found.")
end
