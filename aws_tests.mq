# =========================================================================
# Lambda Tests
# =========================================================================

| let lambda_list_functions_json = "{\"Functions\":[{\"FunctionName\":\"process-orders\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:process-orders\",\"Runtime\":\"python3.11\",\"Handler\":\"lambda_function.lambda_handler\",\"CodeSize\":2048,\"Description\":\"Process incoming orders\",\"Timeout\":30,\"MemorySize\":128,\"LastModified\":\"2024-06-01T00:00:00Z\",\"State\":\"Active\"},{\"FunctionName\":\"send-notifications\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:send-notifications\",\"Runtime\":\"nodejs20.x\",\"Handler\":\"index.handler\",\"CodeSize\":4096,\"Description\":\"Send email notifications\",\"Timeout\":60,\"MemorySize\":256,\"LastModified\":\"2024-06-02T00:00:00Z\",\"State\":\"Active\"},{\"FunctionName\":\"generate-reports\",\"FunctionArn\":\"arn:aws:lambda:us-east-1:123456789012:function:generate-reports\",\"Runtime\":\"python3.11\",\"Handler\":\"reports.generate\",\"CodeSize\":8192,\"Description\":\"Generate monthly reports\",\"Timeout\":300,\"MemorySize\":512,\"LastModified\":\"2024-06-03T00:00:00Z\",\"State\":\"Inactive\"}]}" |

def test_lambda_functions_count():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::functions(response)
  | assert_eq(len(result), 3)
end

def test_lambda_function_names():
  let response = json::json_parse(lambda_list_functions_json)
  | let names = aws::lambda::function_names(response)
  | assert_eq(names, ["process-orders", "send-notifications", "generate-reports"])
end

def test_lambda_by_runtime_python():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "python3.11")
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["FunctionName"], "process-orders")
  | assert_eq(result[1]["FunctionName"], "generate-reports")
end

def test_lambda_by_runtime_node():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "nodejs20.x")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["FunctionName"], "send-notifications")
end

def test_lambda_by_runtime_none():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_runtime(response, "ruby3.2")
  | assert_empty(result)
end

def test_lambda_by_state_active():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_state(response, "Active")
  | assert_eq(len(result), 2)
end

def test_lambda_by_state_inactive():
  let response = json::json_parse(lambda_list_functions_json)
  | let result = aws::lambda::by_state(response, "Inactive")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["FunctionName"], "generate-reports")
end

def test_lambda_total_memory():
  let response = json::json_parse(lambda_list_functions_json)
  | let total = aws::lambda::total_memory(response)
  | assert_eq(total, 896)
end

def test_lambda_total_memory_empty():
  let response = json::json_parse("{\"Functions\":[]}")
  | let total = aws::lambda::total_memory(response)
  | assert_eq(total, 0)
end

def test_lambda_functions_empty():
  let response = json::json_parse("{\"Functions\":[]}")
  | let result = aws::lambda::functions(response)
  | assert_empty(result)
end

def test_lambda_functions_to_markdown_table():
  let response = json::json_parse(lambda_list_functions_json)
