# SES Tests — Identities
# =========================================================================

| let ses_identities_json = "{\"Identities\":[\"example.com\",\"admin@example.com\",\"noreply@example.com\"]}" |

def test_ses_identities_count():
  let response = json::json_parse(ses_identities_json)
  | let count = aws::ses::identity_count(response)
  | assert_eq(count, 3)
end

def test_ses_identities_list():
  let response = json::json_parse(ses_identities_json)
  | let result = aws::ses::identities(response)
  | assert_eq(result, ["example.com", "admin@example.com", "noreply@example.com"])
end

def test_ses_identities_empty():
  let response = json::json_parse("{\"Identities\":[]}")
  | let result = aws::ses::identities(response)
  | assert_empty(result)
end

def test_ses_identities_to_markdown_table():
  let response = json::json_parse(ses_identities_json)
  | let result = aws::ses::identities_to_markdown_table(response)
  | assert(contains(result, "| Identity |"))
  | assert(contains(result, "example.com"))
  | assert(contains(result, "admin@example.com"))
end

def test_ses_identities_to_markdown_table_empty():
  let response = json::json_parse("{\"Identities\":[]}")
  | let result = aws::ses::identities_to_markdown_table(response)
  | assert_eq(result, "No identities found.")
end

