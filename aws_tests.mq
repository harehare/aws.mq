  | let result = aws::ses::send_statistics(response)
  | assert_empty(result)
end

def test_ses_send_statistics_to_markdown_table():
  let response = json::json_parse(ses_stats_json)
  | let result = aws::ses::send_statistics_to_markdown_table(response)
  | assert(contains(result, "| Timestamp | DeliveryAttempts | Bounces | Complaints | Rejects |"))
  | assert(contains(result, "2024-06-15T00:00:00Z"))
  | assert(contains(result, "500"))
  | assert(contains(result, "10"))
end

