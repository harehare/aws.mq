import "json"
| import "aws"
| include "test"

# =========================================================================
# EC2 Tests — Instances
# =========================================================================

| let ec2_instances_json = "{\"Reservations\":[{\"ReservationId\":\"r-001\",\"Instances\":[{\"InstanceId\":\"i-001\",\"InstanceType\":\"t3.micro\",\"State\":{\"Name\":\"running\",\"Code\":16},\"PublicIpAddress\":\"1.2.3.4\",\"PrivateIpAddress\":\"10.0.1.1\",\"ImageId\":\"ami-001\",\"LaunchTime\":\"2024-01-01T00:00:00Z\",\"Tags\":[{\"Key\":\"Name\",\"Value\":\"web-server\"},{\"Key\":\"Env\",\"Value\":\"prod\"}],\"Placement\":{\"AvailabilityZone\":\"us-east-1a\"},\"VpcId\":\"vpc-001\",\"SubnetId\":\"subnet-001\"},{\"InstanceId\":\"i-002\",\"InstanceType\":\"t3.large\",\"State\":{\"Name\":\"stopped\",\"Code\":80},\"PrivateIpAddress\":\"10.0.1.2\",\"Tags\":[{\"Key\":\"Name\",\"Value\":\"db-server\"}],\"Placement\":{\"AvailabilityZone\":\"us-east-1b\"},\"VpcId\":\"vpc-001\",\"SubnetId\":\"subnet-002\"}]},{\"ReservationId\":\"r-002\",\"Instances\":[{\"InstanceId\":\"i-003\",\"InstanceType\":\"t3.micro\",\"State\":{\"Name\":\"running\",\"Code\":16},\"PublicIpAddress\":\"5.6.7.8\",\"PrivateIpAddress\":\"10.0.2.1\",\"Tags\":[],\"Placement\":{\"AvailabilityZone\":\"us-east-1a\"},\"VpcId\":\"vpc-002\",\"SubnetId\":\"subnet-003\"}]}]}" |

def test_ec2_instances_count():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances(response)
  | assert_eq(len(result), 3)
end

def test_ec2_instances_ids():
  let response = json::json_parse(ec2_instances_json)
  | let ids = aws::ec2::instance_ids(response)
  | assert_eq(ids, ["i-001", "i-002", "i-003"])
end

def test_ec2_running_instances():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::running_instances(response)
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["InstanceId"], "i-001")
  | assert_eq(result[1]["InstanceId"], "i-003")
end

def test_ec2_stopped_instances():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::stopped_instances(response)
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["InstanceId"], "i-002")
end

def test_ec2_instances_by_state_terminated():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances_by_state(response, "terminated")
  | assert_empty(result)
end

def test_ec2_instances_by_type():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances_by_type(response, "t3.micro")
  | assert_eq(len(result), 2)
end

def test_ec2_instances_by_type_large():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances_by_type(response, "t3.large")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["InstanceId"], "i-002")
end

def test_ec2_instance_name():
  let response = json::json_parse(ec2_instances_json)
  | let insts = aws::ec2::instances(response)
  | let name = aws::ec2::instance_name(insts[0])
  | assert_eq(name, "web-server")
end

def test_ec2_instance_name_no_tags():
  let response = json::json_parse(ec2_instances_json)
  | let insts = aws::ec2::instances(response)
  | let name = aws::ec2::instance_name(insts[2])
  | assert_eq(name, "")
end

def test_ec2_instances_empty_reservations():
  let response = json::json_parse("{\"Reservations\":[]}")
  | let result = aws::ec2::instances(response)
  | assert_empty(result)
end

def test_ec2_instances_null_reservations():
  let response = json::json_parse("{}")
  | let result = aws::ec2::instances(response)
  | assert_empty(result)
end

def test_ec2_instances_to_markdown_table_header():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances_to_markdown_table(response)
  | assert(contains(result, "| InstanceId | Name | Type | State | PrivateIP | PublicIP | AZ |"))
end

def test_ec2_instances_to_markdown_table_content():
  let response = json::json_parse(ec2_instances_json)
  | let result = aws::ec2::instances_to_markdown_table(response)
  | assert(contains(result, "i-001"))
  | assert(contains(result, "web-server"))
  | assert(contains(result, "running"))
  | assert(contains(result, "i-002"))
  | assert(contains(result, "db-server"))
  | assert(contains(result, "stopped"))
end

def test_ec2_instances_to_markdown_table_empty():
  let response = json::json_parse("{\"Reservations\":[]}")
  | let result = aws::ec2::instances_to_markdown_table(response)
  | assert_eq(result, "No instances found.")
end

# =========================================================================
# EC2 Tests — Security Groups
# =========================================================================

| let ec2_security_groups_json = "{\"SecurityGroups\":[{\"GroupId\":\"sg-001\",\"GroupName\":\"web-sg\",\"Description\":\"Web server security group\",\"VpcId\":\"vpc-001\",\"Tags\":[{\"Key\":\"Name\",\"Value\":\"web-sg\"}]},{\"GroupId\":\"sg-002\",\"GroupName\":\"db-sg\",\"Description\":\"Database security group\",\"VpcId\":\"vpc-001\",\"Tags\":[{\"Key\":\"Name\",\"Value\":\"db-sg\"}]},{\"GroupId\":\"sg-003\",\"GroupName\":\"default\",\"Description\":\"Default VPC security group\",\"VpcId\":\"vpc-002\",\"Tags\":[]}]}" |

def test_ec2_security_groups_count():
  let response = json::json_parse(ec2_security_groups_json)
  | let result = aws::ec2::security_groups(response)
  | assert_eq(len(result), 3)
end

def test_ec2_security_groups_by_vpc():
  let response = json::json_parse(ec2_security_groups_json)
  | let result = aws::ec2::security_groups_by_vpc(response, "vpc-001")
  | assert_eq(len(result), 2)
  | assert_eq(result[0]["GroupName"], "web-sg")
  | assert_eq(result[1]["GroupName"], "db-sg")
end

def test_ec2_security_groups_by_vpc_other():
  let response = json::json_parse(ec2_security_groups_json)
  | let result = aws::ec2::security_groups_by_vpc(response, "vpc-002")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["GroupName"], "default")
end

def test_ec2_security_groups_empty():
  let response = json::json_parse("{\"SecurityGroups\":[]}")
  | let result = aws::ec2::security_groups(response)
  | assert_empty(result)
end

def test_ec2_security_groups_to_markdown_table():
  let response = json::json_parse(ec2_security_groups_json)
  | let result = aws::ec2::security_groups_to_markdown_table(response)
  | assert(contains(result, "| GroupId | GroupName | Description | VpcId |"))
  | assert(contains(result, "sg-001"))
  | assert(contains(result, "web-sg"))
  | assert(contains(result, "vpc-001"))
end

def test_ec2_security_groups_to_markdown_table_empty():
  let response = json::json_parse("{\"SecurityGroups\":[]}")
  | let result = aws::ec2::security_groups_to_markdown_table(response)
  | assert_eq(result, "No security groups found.")
end

