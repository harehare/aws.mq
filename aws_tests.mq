| let ec2_vpcs_json = "{\"Vpcs\":[{\"VpcId\":\"vpc-001\",\"CidrBlock\":\"10.0.0.0/16\",\"IsDefault\":false,\"State\":\"available\",\"Tags\":[{\"Key\":\"Name\",\"Value\":\"main-vpc\"}]},{\"VpcId\":\"vpc-002\",\"CidrBlock\":\"172.31.0.0/16\",\"IsDefault\":true,\"State\":\"available\",\"Tags\":[]}]}" |

def test_ec2_vpcs_count():
