| let iam_list_groups_json = "{\"Groups\":[{\"GroupName\":\"Admins\",\"GroupId\":\"AGPA001\",\"Arn\":\"arn:aws:iam::123456789012:group/Admins\",\"Path\":\"/\",\"CreateDate\":\"2024-01-01T00:00:00Z\"},{\"GroupName\":\"Developers\",\"GroupId\":\"AGPA002\",\"Arn\":\"arn:aws:iam::123456789012:group/Developers\",\"Path\":\"/\",\"CreateDate\":\"2024-02-01T00:00:00Z\"},{\"GroupName\":\"ReadOnly\",\"GroupId\":\"AGPA003\",\"Arn\":\"arn:aws:iam::123456789012:group/ReadOnly\",\"Path\":\"/\",\"CreateDate\":\"2024-03-01T00:00:00Z\"}]}" |

def test_iam_groups_count():
  let response = json::json_parse(iam_list_groups_json)
  | let result = aws::iam::groups(response)
  | assert_eq(len(result), 3)
end

def test_iam_group_names():
  let response = json::json_parse(iam_list_groups_json)
  | let names = aws::iam::group_names(response)
  | assert_eq(names, ["Admins", "Developers", "ReadOnly"])
end

def test_iam_groups_empty():
  let response = json::json_parse("{\"Groups\":[]}")
  | let result = aws::iam::groups(response)
  | assert_empty(result)
end

def test_iam_groups_to_markdown_table():
  let response = json::json_parse(iam_list_groups_json)
  | let result = aws::iam::groups_to_markdown_table(response)
  | assert(contains(result, "| GroupName | GroupId | Arn | CreateDate |"))
  | assert(contains(result, "Admins"))
  | assert(contains(result, "AGPA001"))
  | assert(contains(result, "arn:aws:iam::123456789012:group/Admins"))
end

def test_iam_groups_to_markdown_table_empty():
  let response = json::json_parse("{\"Groups\":[]}")
  | let result = aws::iam::groups_to_markdown_table(response)
  | assert_eq(result, "No groups found.")
end

