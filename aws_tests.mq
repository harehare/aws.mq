| let iam_list_users_json = "{\"Users\":[{\"UserName\":\"alice\",\"UserId\":\"AIDA001\",\"Arn\":\"arn:aws:iam::123456789012:user/alice\",\"Path\":\"/\",\"CreateDate\":\"2024-01-01T00:00:00Z\"},{\"UserName\":\"bob\",\"UserId\":\"AIDA002\",\"Arn\":\"arn:aws:iam::123456789012:user/bob\",\"Path\":\"/\",\"CreateDate\":\"2024-02-01T00:00:00Z\"},{\"UserName\":\"charlie\",\"UserId\":\"AIDA003\",\"Arn\":\"arn:aws:iam::123456789012:user/charlie\",\"Path\":\"/devops/\",\"CreateDate\":\"2024-03-01T00:00:00Z\"}]}" |

def test_iam_users_count():
  let response = json::json_parse(iam_list_users_json)
  | let result = aws::iam::users(response)
  | assert_eq(len(result), 3)
end

def test_iam_usernames():
  let response = json::json_parse(iam_list_users_json)
  | let names = aws::iam::usernames(response)
  | assert_eq(names, ["alice", "bob", "charlie"])
end

def test_iam_users_empty():
  let response = json::json_parse("{\"Users\":[]}")
  | let result = aws::iam::users(response)
  | assert_empty(result)
end

def test_iam_users_to_markdown_table():
  let response = json::json_parse(iam_list_users_json)
  | let result = aws::iam::users_to_markdown_table(response)
  | assert(contains(result, "| UserName | UserId | Arn | CreateDate |"))
  | assert(contains(result, "alice"))
  | assert(contains(result, "AIDA001"))
  | assert(contains(result, "arn:aws:iam::123456789012:user/alice"))
end

def test_iam_users_to_markdown_table_empty():
  let response = json::json_parse("{\"Users\":[]}")
  | let result = aws::iam::users_to_markdown_table(response)
  | assert_eq(result, "No users found.")
end

