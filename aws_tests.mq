| let s3_list_buckets_json = "{\"Buckets\":[{\"Name\":\"my-app-assets\",\"CreationDate\":\"2024-01-01T00:00:00Z\"},{\"Name\":\"my-app-logs\",\"CreationDate\":\"2024-02-01T00:00:00Z\"},{\"Name\":\"my-backups\",\"CreationDate\":\"2024-03-01T00:00:00Z\"}],\"Owner\":{\"DisplayName\":\"myaccount\",\"ID\":\"abc123\"}}" |

def test_s3_buckets_count():
  let response = json::json_parse(s3_list_buckets_json)
  | let result = aws::s3::buckets(response)
  | assert_eq(len(result), 3)
end

def test_s3_bucket_names():
  let response = json::json_parse(s3_list_buckets_json)
  | let names = aws::s3::bucket_names(response)
  | assert_eq(names, ["my-app-assets", "my-app-logs", "my-backups"])
end

def test_s3_buckets_empty():
  let response = json::json_parse("{\"Buckets\":[]}")
  | let result = aws::s3::buckets(response)
  | assert_empty(result)
end

def test_s3_buckets_null():
  let response = json::json_parse("{}")
  | let result = aws::s3::buckets(response)
  | assert_empty(result)
end

def test_s3_buckets_to_markdown_table():
  let response = json::json_parse(s3_list_buckets_json)
  | let result = aws::s3::buckets_to_markdown_table(response)
  | assert(contains(result, "| Name | CreationDate |"))
  | assert(contains(result, "my-app-assets"))
  | assert(contains(result, "my-backups"))
end

def test_s3_buckets_to_markdown_table_empty():
  let response = json::json_parse("{\"Buckets\":[]}")
  | let result = aws::s3::buckets_to_markdown_table(response)
  | assert_eq(result, "No buckets found.")
end

# =========================================================================
# S3 Tests — Objects
# =========================================================================

| let s3_list_objects_json = "{\"Contents\":[{\"Key\":\"images/logo.png\",\"Size\":10240,\"LastModified\":\"2024-06-01T00:00:00Z\",\"StorageClass\":\"STANDARD\"},{\"Key\":\"images/banner.jpg\",\"Size\":51200,\"LastModified\":\"2024-06-02T00:00:00Z\",\"StorageClass\":\"STANDARD\"},{\"Key\":\"docs/readme.pdf\",\"Size\":204800,\"LastModified\":\"2024-06-03T00:00:00Z\",\"StorageClass\":\"STANDARD_IA\"}],\"KeyCount\":3,\"MaxKeys\":1000,\"IsTruncated\":false}" |

def test_s3_objects_count():
  let response = json::json_parse(s3_list_objects_json)
  | let result = aws::s3::objects(response)
  | assert_eq(len(result), 3)
end

def test_s3_object_keys():
  let response = json::json_parse(s3_list_objects_json)
  | let keys = aws::s3::object_keys(response)
  | assert_eq(len(keys), 3)
  | assert_eq(keys[0], "images/logo.png")
  | assert_eq(keys[1], "images/banner.jpg")
  | assert_eq(keys[2], "docs/readme.pdf")
end

def test_s3_total_size():
  let response = json::json_parse(s3_list_objects_json)
  | let size = aws::s3::total_size(response)
  | assert_eq(size, 266240)
end

def test_s3_total_size_empty():
  let response = json::json_parse("{\"Contents\":[]}")
  | let size = aws::s3::total_size(response)
  | assert_eq(size, 0)
end

def test_s3_objects_by_storage_class():
  let response = json::json_parse(s3_list_objects_json)
  | let result = aws::s3::objects_by_storage_class(response, "STANDARD")
  | assert_eq(len(result), 2)
end

def test_s3_objects_by_storage_class_ia():
  let response = json::json_parse(s3_list_objects_json)
  | let result = aws::s3::objects_by_storage_class(response, "STANDARD_IA")
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["Key"], "docs/readme.pdf")
end

def test_s3_objects_to_markdown_table():
  let response = json::json_parse(s3_list_objects_json)
  | let result = aws::s3::objects_to_markdown_table(response)
  | assert(contains(result, "| Key | Size | LastModified | StorageClass |"))
  | assert(contains(result, "images/logo.png"))
  | assert(contains(result, "10240"))
  | assert(contains(result, "STANDARD_IA"))
end

def test_s3_objects_to_markdown_table_empty():
  let response = json::json_parse("{\"Contents\":[]}")
  | let result = aws::s3::objects_to_markdown_table(response)
  | assert_eq(result, "No objects found.")
end

