| let ses_stats_json = "{\"SendDataPoints\":[{\"Timestamp\":\"2024-06-15T00:00:00Z\",\"DeliveryAttempts\":500,\"Bounces\":10,\"Complaints\":2,\"Rejects\":1},{\"Timestamp\":\"2024-06-14T00:00:00Z\",\"DeliveryAttempts\":450,\"Bounces\":8,\"Complaints\":1,\"Rejects\":0},{\"Timestamp\":\"2024-06-13T00:00:00Z\",\"DeliveryAttempts\":600,\"Bounces\":15,\"Complaints\":3,\"Rejects\":2}]}" |

def test_ses_total_deliveries():
  let response = json::json_parse(ses_stats_json)
  | let total = aws::ses::total_deliveries(response)
  | assert_eq(total, 1550)
end

def test_ses_total_bounces():
  let response = json::json_parse(ses_stats_json)
  | let total = aws::ses::total_bounces(response)
  | assert_eq(total, 33)
end

def test_ses_total_complaints():
  let response = json::json_parse(ses_stats_json)
  | let total = aws::ses::total_complaints(response)
  | assert_eq(total, 6)
end

def test_ses_send_statistics_empty():
