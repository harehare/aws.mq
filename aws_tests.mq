  | let result = aws::ec2::vpcs(response)
  | assert_eq(len(result), 2)
end

def test_ec2_default_vpc():
  let response = json::json_parse(ec2_vpcs_json)
  | let result = aws::ec2::default_vpc(response)
  | assert_eq(result["VpcId"], "vpc-002")
  | assert_eq(result["IsDefault"], true)
end

def test_ec2_vpcs_to_markdown_table():
  let response = json::json_parse(ec2_vpcs_json)
  | let result = aws::ec2::vpcs_to_markdown_table(response)
  | assert(contains(result, "| VpcId | CidrBlock | IsDefault | State | Name |"))
  | assert(contains(result, "vpc-001"))
  | assert(contains(result, "10.0.0.0/16"))
  | assert(contains(result, "main-vpc"))
  | assert(contains(result, "false"))
  | assert(contains(result, "true"))
end

def test_ec2_vpcs_to_markdown_table_empty():
  let response = json::json_parse("{\"Vpcs\":[]}")
  | let result = aws::ec2::vpcs_to_markdown_table(response)
  | assert_eq(result, "No VPCs found.")
end

