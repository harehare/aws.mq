  | let result = aws::sagemaker::training_jobs_to_markdown_table(response)
  | assert_eq(result, "No training jobs found.")
end

| let sagemaker_models_json = "{\"Models\":[{\"ModelName\":\"bert-model-v1\",\"ModelArn\":\"arn:aws:sagemaker:us-east-1:123456789012:model/bert-model-v1\",\"CreationTime\":\"2024-01-10T14:00:00Z\"},{\"ModelName\":\"gpt-model-v1\",\"ModelArn\":\"arn:aws:sagemaker:us-east-1:123456789012:model/gpt-model-v1\",\"CreationTime\":\"2024-01-12T10:00:00Z\"}]}" |

def test_sagemaker_models():
  let response = json::json_parse(sagemaker_models_json)
  | let result = aws::sagemaker::models(response)
  | assert_eq(len(result), 2)
end

def test_sagemaker_model_names():
  let response = json::json_parse(sagemaker_models_json)
  | let result = aws::sagemaker::model_names(response)
  | assert_eq(len(result), 2)
  | assert_eq(result[0], "bert-model-v1")
end

def test_sagemaker_models_to_markdown_table():
  let response = json::json_parse(sagemaker_models_json)
  | let result = aws::sagemaker::models_to_markdown_table(response)
  | assert(contains(result, "| ModelName | ModelArn | CreationTime |"))
  | assert(contains(result, "bert-model-v1"))
  | assert(contains(result, "gpt-model-v1"))
end

def test_sagemaker_models_to_markdown_table_empty():
  let response = json::json_parse("{\"Models\":[]}")
  | let result = aws::sagemaker::models_to_markdown_table(response)
  | assert_eq(result, "No models found.")
end

| let sagemaker_endpoints_json = "{\"Endpoints\":[{\"EndpointName\":\"bert-endpoint\",\"EndpointArn\":\"arn:aws:sagemaker:us-east-1:123456789012:endpoint/bert-endpoint\",\"EndpointStatus\":\"InService\",\"CreationTime\":\"2024-01-11T08:00:00Z\",\"LastModifiedTime\":\"2024-01-11T09:00:00Z\"},{\"EndpointName\":\"gpt-endpoint\",\"EndpointArn\":\"arn:aws:sagemaker:us-east-1:123456789012:endpoint/gpt-endpoint\",\"EndpointStatus\":\"Creating\",\"CreationTime\":\"2024-01-15T07:00:00Z\",\"LastModifiedTime\":\"2024-01-15T07:05:00Z\"},{\"EndpointName\":\"legacy-endpoint\",\"EndpointArn\":\"arn:aws:sagemaker:us-east-1:123456789012:endpoint/legacy-endpoint\",\"EndpointStatus\":\"Failed\",\"CreationTime\":\"2024-01-01T08:00:00Z\",\"LastModifiedTime\":\"2024-01-01T09:00:00Z\"}]}" |

def test_sagemaker_endpoints():
  let response = json::json_parse(sagemaker_endpoints_json)
  | let result = aws::sagemaker::endpoints(response)
  | assert_eq(len(result), 3)
end

def test_sagemaker_in_service_endpoints():
  let response = json::json_parse(sagemaker_endpoints_json)
  | let result = aws::sagemaker::in_service_endpoints(response)
  | assert_eq(len(result), 1)
  | assert_eq(result[0]["EndpointName"], "bert-endpoint")
end

def test_sagemaker_endpoint_names():
  let response = json::json_parse(sagemaker_endpoints_json)
  | let result = aws::sagemaker::endpoint_names(response)
  | assert_eq(len(result), 3)
  | assert_eq(result[0], "bert-endpoint")
end

def test_sagemaker_endpoints_to_markdown_table():
  let response = json::json_parse(sagemaker_endpoints_json)
  | let result = aws::sagemaker::endpoints_to_markdown_table(response)
  | assert(contains(result, "| EndpointName | Status | CreationTime | LastModifiedTime |"))
  | assert(contains(result, "bert-endpoint"))
  | assert(contains(result, "InService"))
  | assert(contains(result, "Creating"))
  | assert(contains(result, "Failed"))
end

def test_sagemaker_endpoints_to_markdown_table_empty():
  let response = json::json_parse("{\"Endpoints\":[]}")
  | let result = aws::sagemaker::endpoints_to_markdown_table(response)
  | assert_eq(result, "No endpoints found.")
end
