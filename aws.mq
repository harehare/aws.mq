module cognito:
  # Extract user pools from a ListUserPools response.
  def user_pools(response):
    if (is_none(response["UserPools"])): [] else: response["UserPools"]
  end

  # Get all user pool names.
  def user_pool_names(response):
    map(user_pools(response), fn(p): p["Name"];)
  end

  # Convert a ListUserPools response to a Markdown table.
  def user_pools_to_markdown_table(response):
    let data = user_pools(response)
    | if (is_empty(data)):
        "No user pools found."
      else:
        do
          let header = "| Name | Id | Status | CreationDate | LastModifiedDate |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(p):
                      "| " + _aws_to_cell(p["Name"]) +
                        " | " + _aws_to_cell(p["Id"]) +
                        " | " + _aws_to_cell(p["Status"]) +
                        " | " + _aws_to_cell(p["CreationDate"]) +
                        " | " + _aws_to_cell(p["LastModifiedDate"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract users from a ListUsers response.
  def users(response):
    if (is_none(response["Users"])): [] else: response["Users"]
  end

  # Get all usernames.
  def usernames(response):
    map(users(response), fn(u): u["Username"];)
  end

  # Filter confirmed (active) users.
  def confirmed_users(response):
    filter(users(response), fn(u): u["UserStatus"] == "CONFIRMED";)
  end

  # Filter users by status (e.g. "CONFIRMED", "UNCONFIRMED", "FORCE_CHANGE_PASSWORD").
  def users_by_status(response, status):
    filter(users(response), fn(u): u["UserStatus"] == status;)
  end

  # Filter enabled users.
  def enabled_users(response):
    filter(users(response), fn(u): u["Enabled"] == true;)
  end

  # Get a user attribute value by name.
  def user_attribute(user, name):
    let attrs = if (is_none(user["Attributes"])): [] else: user["Attributes"]
    | let matches = filter(attrs, fn(a): a["Name"] == name;)
    | if (is_empty(matches)): None else: first(matches)["Value"]
  end

  # Convert a ListUsers response to a Markdown table.
  def users_to_markdown_table(response):
    let data = users(response)
    | if (is_empty(data)):
        "No users found."
      else:
        do
          let header = "| Username | Status | Enabled | UserCreateDate |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(u):
                      "| " + _aws_to_cell(u["Username"]) +
                        " | " + _aws_to_cell(u["UserStatus"]) +
                        " | " + _aws_to_cell(u["Enabled"]) +
                        " | " + _aws_to_cell(u["UserCreateDate"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

