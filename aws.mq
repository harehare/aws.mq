module ecr:
  # Extract repositories from a DescribeRepositories response.
  def repositories(response):
    if (is_none(response["repositories"])): [] else: response["repositories"]
  end

  # Get all repository names.
  def repository_names(response):
    map(repositories(response), fn(r): r["repositoryName"];)
  end

  # Convert a DescribeRepositories response to a Markdown table.
  def repositories_to_markdown_table(response):
    let data = repositories(response)
    | if (is_empty(data)):
        "No repositories found."
      else:
        do
          let header = "| RepositoryName | RepositoryUri | CreatedAt |"
          | let sep = "| --- | --- | --- |"
          | let rows = map(data, fn(r):
                      "| " + _aws_to_cell(r["repositoryName"]) +
                        " | " + _aws_to_cell(r["repositoryUri"]) +
                        " | " + _aws_to_cell(r["createdAt"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract image details from a DescribeImages response.
  def images(response):
    if (is_none(response["imageDetails"])): [] else: response["imageDetails"]
  end

  # Get all image tags (flattened across all images).
  def image_tags(response):
    flatten(map(images(response), fn(img):
      if (is_none(img["imageTags"])): [] else: img["imageTags"];
    ))
  end

  # Get total size in bytes across all images.
  def total_image_size(response):
    fold(map(images(response), fn(img): img["imageSizeInBytes"];), 0, fn(acc, s): acc + s;)
  end

  # Convert a DescribeImages response to a Markdown table.
  def images_to_markdown_table(response):
    let data = images(response)
    | if (is_empty(data)):
        "No images found."
      else:
        do
          let header = "| RepositoryName | ImageDigest | Tags | SizeBytes | PushedAt |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(img):
                      let tags = if (is_none(img["imageTags"])): "" else: join(img["imageTags"], ",")
                      | "| " + _aws_to_cell(img["repositoryName"]) +
                        " | " + _aws_to_cell(img["imageDigest"]) +
                        " | " + tags +
                        " | " + _aws_to_cell(img["imageSizeInBytes"]) +
                        " | " + _aws_to_cell(img["imagePushedAt"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

