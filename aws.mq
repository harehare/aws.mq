  end

  # Convert a ListMFADevices response to a Markdown table.
  def mfa_devices_to_markdown_table(response):
    let data = mfa_devices(response)
    | if (is_empty(data)):
        "No MFA devices found."
      else:
        do
          let header = "| UserName | SerialNumber | EnableDate |"
          | let sep = "| --- | --- | --- |"
          | let rows = map(data, fn(d):
                      "| " + _aws_to_cell(d["UserName"]) +
                        " | " + _aws_to_cell(d["SerialNumber"]) +
                        " | " + _aws_to_cell(d["EnableDate"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

