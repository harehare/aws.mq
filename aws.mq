          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(g):
                      let instance_count = if (is_none(g["Instances"])): 0 else: len(g["Instances"])
                      | "| " + _aws_to_cell(g["AutoScalingGroupName"]) +
                        " | " + _aws_to_cell(g["MinSize"]) +
                        " | " + _aws_to_cell(g["MaxSize"]) +
                        " | " + _aws_to_cell(g["DesiredCapacity"]) +
                        " | " + _aws_to_cell(instance_count) + " |"
