  def log_group_names(response):
    map(log_groups(response), fn(g): g["logGroupName"];)
  end

  # Get total stored bytes across all log groups.
  def total_stored_bytes(response):
    fold(map(log_groups(response), fn(g): if (is_none(g["storedBytes"])): 0 else: g["storedBytes"];), 0, fn(acc, s): acc + s;)
  end

