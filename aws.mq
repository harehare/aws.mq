module cloudwatch:
  # Extract metric alarms from a DescribeAlarms response.
  def alarms(response):
    if (is_none(response["MetricAlarms"])): [] else: response["MetricAlarms"]
  end

  # Filter alarms by state ("OK", "ALARM", "INSUFFICIENT_DATA").
  def alarms_in_state(response, state):
    filter(alarms(response), fn(a): a["StateValue"] == state;)
  end

  # Return alarms in the OK state.
  def ok_alarms(response):
    alarms_in_state(response, "OK")
  end

  # Return alarms in the ALARM state.
  def alarm_alarms(response):
    alarms_in_state(response, "ALARM")
  end

  # Return alarms in the INSUFFICIENT_DATA state.
  def insufficient_data_alarms(response):
    alarms_in_state(response, "INSUFFICIENT_DATA")
  end

  # Get all alarm names.
  def alarm_names(response):
    map(alarms(response), fn(a): a["AlarmName"];)
  end

  # Convert a DescribeAlarms response to a Markdown table.
  def alarms_to_markdown_table(response):
    let data = alarms(response)
    | if (is_empty(data)):
        "No alarms found."
      else:
        do
          let header = "| AlarmName | State | Namespace | MetricName | Threshold |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(a):
                      "| " + _aws_to_cell(a["AlarmName"]) +
                        " | " + _aws_to_cell(a["StateValue"]) +
                        " | " + _aws_to_cell(a["Namespace"]) +
                        " | " + _aws_to_cell(a["MetricName"]) +
                        " | " + _aws_to_cell(a["Threshold"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

