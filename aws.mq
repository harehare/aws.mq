  end

  # Filter stages that failed in their latest execution.
  def failed_stages(response):
    filter(stage_states(response), fn(s):
      !is_none(s["latestExecution"]) && s["latestExecution"]["status"] == "Failed";
    )
  end

  # Filter stages currently in progress.
  def in_progress_stages(response):
    filter(stage_states(response), fn(s):
      !is_none(s["latestExecution"]) && s["latestExecution"]["status"] == "InProgress";
    )
  end

  # Convert a GetPipelineState response to a Markdown table.
  def stage_states_to_markdown_table(response):
    let data = stage_states(response)
    | if (is_empty(data)):
        "No stage states found."
      else:
        do
          let header = "| StageName | Status |"
          | let sep = "| --- | --- |"
          | let rows = map(data, fn(s):
                      let status = if (is_none(s["latestExecution"])): "" else: _aws_to_cell(s["latestExecution"]["status"])
                      | "| " + _aws_to_cell(s["stageName"]) +
                        " | " + status + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

