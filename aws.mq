import "json"

|

# AWS API response processing module for mq
# Provides helpers for processing AWS CLI / SDK JSON responses.
# See https://docs.aws.amazon.com/cli/latest/reference/ for API response schemas.

# Parse a raw JSON string into a value (shorthand for json::json_parse).
def from_json(s):
  json::json_parse(s)
end

# Extract a tag value by key from an AWS Tags array [{Key, Value}].
def _aws_tag_value(tags, key):
  if (is_none(tags) || is_empty(tags)):
    ""
  else:
    do
      let matches = filter(tags, fn(t): t["Key"] == key;)
      | if (is_empty(matches)): "" else: first(matches)["Value"]
    end
end

# Format a value as a Markdown table cell string.
def _aws_to_cell(value):
  if (is_none(value)): ""
  elif (is_bool(value)): to_string(value)
  elif (is_array(value)): to_string(len(value)) + " items"
  elif (is_dict(value)): "{...}"
  else: to_string(value)
end

# Build a Markdown table from a header row string, separator string, and data rows.
def _aws_table(header, sep, rows):
  join([header, sep] + rows, "\n")
end

|

module ec2:
  # Extract all instances from a DescribeInstances response.
  def instances(response):
    if (is_none(response["Reservations"]) || is_empty(response["Reservations"])):
      []
    else:
      flatten(map(response["Reservations"], fn(r): r["Instances"];))
  end

  # Filter instances by state name (e.g. "running", "stopped", "terminated").
  def instances_by_state(response, state):
    filter(instances(response), fn(i): !is_none(i["State"]) && i["State"]["Name"] == state;)
  end

  # Return only running instances.
  def running_instances(response):
    instances_by_state(response, "running")
  end

  # Return only stopped instances.
  def stopped_instances(response):
    instances_by_state(response, "stopped")
  end

  # Filter instances by instance type (e.g. "t3.micro").
  def instances_by_type(response, instance_type):
    filter(instances(response), fn(i): i["InstanceType"] == instance_type;)
  end

  # Get all instance IDs from a DescribeInstances response.
  def instance_ids(response):
    map(instances(response), fn(i): i["InstanceId"];)
  end

  # Get the Name tag value for an instance.
  def instance_name(instance):
    _aws_tag_value(instance["Tags"], "Name")
  end

  # Convert a DescribeInstances response to a Markdown table.
  def instances_to_markdown_table(response):
    let data = instances(response)
    | if (is_empty(data)):
        "No instances found."
      else:
        do
          let header = "| InstanceId | Name | Type | State | PrivateIP | PublicIP | AZ |"
          | let sep = "| --- | --- | --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(i):
                      "| " + _aws_to_cell(i["InstanceId"]) +
                        " | " + _aws_tag_value(i["Tags"], "Name") +
                        " | " + _aws_to_cell(i["InstanceType"]) +
                        " | " + (if (is_none(i["State"])): "" else: _aws_to_cell(i["State"]["Name"])) +
                        " | " + _aws_to_cell(i["PrivateIpAddress"]) +
                        " | " + _aws_to_cell(i["PublicIpAddress"]) +
                        " | " + (if (is_none(i["Placement"])): "" else: _aws_to_cell(i["Placement"]["AvailabilityZone"])) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract security groups from a DescribeSecurityGroups response.
  def security_groups(response):
    if (is_none(response["SecurityGroups"])): [] else: response["SecurityGroups"]
  end

  # Filter security groups by VPC ID.
  def security_groups_by_vpc(response, vpc_id):
    filter(security_groups(response), fn(sg): sg["VpcId"] == vpc_id;)
  end

  # Convert a DescribeSecurityGroups response to a Markdown table.
  def security_groups_to_markdown_table(response):
    let data = security_groups(response)
    | if (is_empty(data)):
        "No security groups found."
      else:
        do
          let header = "| GroupId | GroupName | Description | VpcId |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(sg):
                      "| " + _aws_to_cell(sg["GroupId"]) +
                        " | " + _aws_to_cell(sg["GroupName"]) +
                        " | " + _aws_to_cell(sg["Description"]) +
                        " | " + _aws_to_cell(sg["VpcId"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract VPCs from a DescribeVpcs response.
  def vpcs(response):
    if (is_none(response["Vpcs"])): [] else: response["Vpcs"]
  end

  # Return the default VPC, or None if none exists.
  def default_vpc(response):
    first(filter(vpcs(response), fn(v): v["IsDefault"] == true;))
  end

  # Convert a DescribeVpcs response to a Markdown table.
  def vpcs_to_markdown_table(response):
    let data = vpcs(response)
    | if (is_empty(data)):
        "No VPCs found."
      else:
        do
          let header = "| VpcId | CidrBlock | IsDefault | State | Name |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(v):
                      "| " + _aws_to_cell(v["VpcId"]) +
                        " | " + _aws_to_cell(v["CidrBlock"]) +
                        " | " + _aws_to_cell(v["IsDefault"]) +
                        " | " + _aws_to_cell(v["State"]) +
                        " | " + _aws_tag_value(v["Tags"], "Name") + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract subnets from a DescribeSubnets response.
  def subnets(response):
    if (is_none(response["Subnets"])): [] else: response["Subnets"]
  end

  # Filter subnets by VPC ID.
  def subnets_by_vpc(response, vpc_id):
    filter(subnets(response), fn(s): s["VpcId"] == vpc_id;)
  end

  # Convert a DescribeSubnets response to a Markdown table.
  def subnets_to_markdown_table(response):
    let data = subnets(response)
    | if (is_empty(data)):
        "No subnets found."
      else:
        do
          let header = "| SubnetId | VpcId | CidrBlock | AZ | AvailableIPs | Name |"
          | let sep = "| --- | --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(s):
                      "| " + _aws_to_cell(s["SubnetId"]) +
                        " | " + _aws_to_cell(s["VpcId"]) +
                        " | " + _aws_to_cell(s["CidrBlock"]) +
                        " | " + _aws_to_cell(s["AvailabilityZone"]) +
                        " | " + _aws_to_cell(s["AvailableIpAddressCount"]) +
                        " | " + _aws_tag_value(s["Tags"], "Name") + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract AMIs from a DescribeImages response.
  def images(response):
    if (is_none(response["Images"])): [] else: response["Images"]
  end

  # Filter available AMIs.
  def available_images(response):
    filter(images(response), fn(i): i["State"] == "available";)
  end

  # Filter AMIs by owner ID.
  def images_by_owner(response, owner_id):
    filter(images(response), fn(i): i["OwnerId"] == owner_id;)
  end

  # Convert a DescribeImages response to a Markdown table.
  def images_to_markdown_table(response):
    let data = images(response)
    | if (is_empty(data)):
        "No images found."
      else:
        do
          let header = "| ImageId | Name | State | Architecture | OwnerId |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(i):
                      "| " + _aws_to_cell(i["ImageId"]) +
                        " | " + _aws_to_cell(i["Name"]) +
                        " | " + _aws_to_cell(i["State"]) +
                        " | " + _aws_to_cell(i["Architecture"]) +
                        " | " + _aws_to_cell(i["OwnerId"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract Elastic IP addresses from a DescribeAddresses response.
  def addresses(response):
    if (is_none(response["Addresses"])): [] else: response["Addresses"]
  end

  # Filter unassociated Elastic IPs (not attached to any instance).
  def unassociated_addresses(response):
    filter(addresses(response), fn(a): is_none(a["AssociationId"]);)
  end

  # Convert a DescribeAddresses response to a Markdown table.
  def addresses_to_markdown_table(response):
    let data = addresses(response)
    | if (is_empty(data)):
        "No Elastic IPs found."
      else:
        do
          let header = "| PublicIp | AllocationId | InstanceId | Domain |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(a):
                      "| " + _aws_to_cell(a["PublicIp"]) +
                        " | " + _aws_to_cell(a["AllocationId"]) +
                        " | " + _aws_to_cell(a["InstanceId"]) +
                        " | " + _aws_to_cell(a["Domain"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract NAT Gateways from a DescribeNatGateways response.
  def nat_gateways(response):
    if (is_none(response["NatGateways"])): [] else: response["NatGateways"]
  end

  # Filter available NAT Gateways.
  def available_nat_gateways(response):
    filter(nat_gateways(response), fn(n): n["State"] == "available";)
  end

  # Filter NAT Gateways by VPC ID.
  def nat_gateways_by_vpc(response, vpc_id):
    filter(nat_gateways(response), fn(n): n["VpcId"] == vpc_id;)
  end

  # Convert a DescribeNatGateways response to a Markdown table.
  def nat_gateways_to_markdown_table(response):
    let data = nat_gateways(response)
    | if (is_empty(data)):
        "No NAT gateways found."
      else:
        do
          let header = "| NatGatewayId | State | VpcId | SubnetId | PublicIp |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(n):
                      let public_ip = if (is_none(n["NatGatewayAddresses"]) || is_empty(n["NatGatewayAddresses"])): "" else: _aws_to_cell(n["NatGatewayAddresses"][0]["PublicIp"])
                      | "| " + _aws_to_cell(n["NatGatewayId"]) +
                        " | " + _aws_to_cell(n["State"]) +
                        " | " + _aws_to_cell(n["VpcId"]) +
                        " | " + _aws_to_cell(n["SubnetId"]) +
                        " | " + public_ip + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract route tables from a DescribeRouteTables response.
  def route_tables(response):
    if (is_none(response["RouteTables"])): [] else: response["RouteTables"]
  end

  # Filter route tables by VPC ID.
  def route_tables_by_vpc(response, vpc_id):
    filter(route_tables(response), fn(r): r["VpcId"] == vpc_id;)
  end

  # Convert a DescribeRouteTables response to a Markdown table.
  def route_tables_to_markdown_table(response):
    let data = route_tables(response)
    | if (is_empty(data)):
        "No route tables found."
      else:
        do
          let header = "| RouteTableId | VpcId | Routes | Name |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(r):
                      let route_count = if (is_none(r["Routes"])): 0 else: len(r["Routes"])
                      | "| " + _aws_to_cell(r["RouteTableId"]) +
                        " | " + _aws_to_cell(r["VpcId"]) +
                        " | " + _aws_to_cell(route_count) +
                        " | " + _aws_tag_value(r["Tags"], "Name") + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract internet gateways from a DescribeInternetGateways response.
  def internet_gateways(response):
    if (is_none(response["InternetGateways"])): [] else: response["InternetGateways"]
  end

  # Filter internet gateways attached to a specific VPC.
  def internet_gateways_by_vpc(response, vpc_id):
    filter(internet_gateways(response), fn(igw):
      !is_none(igw["Attachments"]) && len(filter(igw["Attachments"], fn(a): a["VpcId"] == vpc_id;)) > 0;
    )
  end

  # Get all internet gateway IDs.
  def internet_gateway_ids(response):
    map(internet_gateways(response), fn(igw): igw["InternetGatewayId"];)
  end

  # Convert a DescribeInternetGateways response to a Markdown table.
  def internet_gateways_to_markdown_table(response):
    let data = internet_gateways(response)
    | if (is_empty(data)):
        "No internet gateways found."
      else:
        do
          let header = "| InternetGatewayId | AttachedVpc | State | Name |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(igw):
                      let first_att = if (is_none(igw["Attachments"]) || is_empty(igw["Attachments"])): None else: igw["Attachments"][0]
                      | let vpc_id = if (is_none(first_att)): "" else: _aws_to_cell(first_att["VpcId"])
                      | let state = if (is_none(first_att)): "detached" else: _aws_to_cell(first_att["State"])
                      | "| " + _aws_to_cell(igw["InternetGatewayId"]) +
                        " | " + vpc_id +
                        " | " + state +
                        " | " + _aws_tag_value(igw["Tags"], "Name") + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract VPC endpoints from a DescribeVpcEndpoints response.
  def vpc_endpoints(response):
    if (is_none(response["VpcEndpoints"])): [] else: response["VpcEndpoints"]
  end

  # Filter VPC endpoints by VPC ID.
  def vpc_endpoints_by_vpc(response, vpc_id):
    filter(vpc_endpoints(response), fn(ep): ep["VpcId"] == vpc_id;)
  end

  # Filter VPC endpoints by type (e.g. "Gateway", "Interface").
  def vpc_endpoints_by_type(response, type):
    filter(vpc_endpoints(response), fn(ep): ep["VpcEndpointType"] == type;)
  end

  # Convert a DescribeVpcEndpoints response to a Markdown table.
  def vpc_endpoints_to_markdown_table(response):
    let data = vpc_endpoints(response)
    | if (is_empty(data)):
        "No VPC endpoints found."
      else:
        do
          let header = "| VpcEndpointId | VpcId | ServiceName | Type | State |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(ep):
                      "| " + _aws_to_cell(ep["VpcEndpointId"]) +
                        " | " + _aws_to_cell(ep["VpcId"]) +
                        " | " + _aws_to_cell(ep["ServiceName"]) +
                        " | " + _aws_to_cell(ep["VpcEndpointType"]) +
                        " | " + _aws_to_cell(ep["State"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

