                      "| " + _aws_to_cell(m["ModelName"]) +
                        " | " + _aws_to_cell(m["ModelArn"]) +
                        " | " + _aws_to_cell(m["CreationTime"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract endpoints from a ListEndpoints response.
  def endpoints(response):
    if (is_none(response["Endpoints"])): [] else: response["Endpoints"]
  end

  # Filter endpoints by status (e.g. "InService", "Creating", "Failed").
  def endpoints_by_status(response, status):
    filter(endpoints(response), fn(e): e["EndpointStatus"] == status;)
  end

  # Return in-service endpoints.
  def in_service_endpoints(response):
    endpoints_by_status(response, "InService")
  end

  # Get all endpoint names.
  def endpoint_names(response):
    map(endpoints(response), fn(e): e["EndpointName"];)
  end

  # Convert a ListEndpoints response to a Markdown table.
  def endpoints_to_markdown_table(response):
    let data = endpoints(response)
    | if (is_empty(data)):
        "No endpoints found."
      else:
        do
          let header = "| EndpointName | Status | CreationTime | LastModifiedTime |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(e):
                      "| " + _aws_to_cell(e["EndpointName"]) +
                        " | " + _aws_to_cell(e["EndpointStatus"]) +
                        " | " + _aws_to_cell(e["CreationTime"]) +
                        " | " + _aws_to_cell(e["LastModifiedTime"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end
