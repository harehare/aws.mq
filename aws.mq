          | let sep = "| --- | --- | --- | --- | --- | --- |"
          | let instance_type = if (is_none(ng["instanceTypes"]) || is_empty(ng["instanceTypes"])): "" else: ng["instanceTypes"][0]
          | let scaling = if (is_none(ng["scalingConfig"])): {} else: ng["scalingConfig"]
          | let row = "| " + _aws_to_cell(ng["nodegroupName"]) +
