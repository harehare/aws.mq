module lambda:
  # Extract functions from a ListFunctions response.
  def functions(response):
    if (is_none(response["Functions"])): [] else: response["Functions"]
  end

  # Get all function names from a ListFunctions response.
  def function_names(response):
    map(functions(response), fn(f): f["FunctionName"];)
  end

  # Filter functions by runtime (e.g. "python3.11", "nodejs20.x").
  def by_runtime(response, runtime):
    filter(functions(response), fn(f): f["Runtime"] == runtime;)
  end

  # Filter functions by state (e.g. "Active", "Inactive").
  def by_state(response, state):
    filter(functions(response), fn(f): f["State"] == state;)
  end

  # Get total allocated memory across all functions in MB.
  def total_memory(response):
    fold(map(functions(response), fn(f): f["MemorySize"];), 0, fn(acc, m): acc + m;)
  end

  # Convert a ListFunctions response to a Markdown table.
  def functions_to_markdown_table(response):
    let data = functions(response)
    | if (is_empty(data)):
        "No functions found."
      else:
        do
          let header = "| FunctionName | Runtime | Handler | MemorySize | Timeout | State |"
          | let sep = "| --- | --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(f):
                      "| " + _aws_to_cell(f["FunctionName"]) +
                        " | " + _aws_to_cell(f["Runtime"]) +
                        " | " + _aws_to_cell(f["Handler"]) +
                        " | " + _aws_to_cell(f["MemorySize"]) +
                        " | " + _aws_to_cell(f["Timeout"]) +
                        " | " + _aws_to_cell(f["State"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract event source mappings from a ListEventSourceMappings response.
  def event_source_mappings(response):
    if (is_none(response["EventSourceMappings"])): [] else: response["EventSourceMappings"]
  end

  # Filter enabled event source mappings.
  def enabled_event_source_mappings(response):
    filter(event_source_mappings(response), fn(m): m["State"] == "Enabled";)
  end

  # Convert a ListEventSourceMappings response to a Markdown table.
  def event_source_mappings_to_markdown_table(response):
    let data = event_source_mappings(response)
    | if (is_empty(data)):
        "No event source mappings found."
      else:
        do
          let header = "| UUID | FunctionArn | EventSourceArn | State | BatchSize |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(m):
                      "| " + _aws_to_cell(m["UUID"]) +
                        " | " + _aws_to_cell(m["FunctionArn"]) +
                        " | " + _aws_to_cell(m["EventSourceArn"]) +
                        " | " + _aws_to_cell(m["State"]) +
                        " | " + _aws_to_cell(m["BatchSize"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract layers from a ListLayers response.
  def layers(response):
    if (is_none(response["Layers"])): [] else: response["Layers"]
  end

  # Get all layer names.
  def layer_names(response):
    map(layers(response), fn(l): l["LayerName"];)
  end

  # Convert a ListLayers response to a Markdown table.
  def layers_to_markdown_table(response):
    let data = layers(response)
    | if (is_empty(data)):
        "No layers found."
      else:
        do
          let header = "| LayerName | LayerArn | LatestVersion | CompatibleRuntimes |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(l):
                      let latest = if (is_none(l["LatestMatchingVersion"])): None else: l["LatestMatchingVersion"]
                      | let version = if (is_none(latest)): "" else: _aws_to_cell(latest["Version"])
                      | let runtimes = if (is_none(latest) || is_none(latest["CompatibleRuntimes"])): "" else: _aws_to_cell(latest["CompatibleRuntimes"])
                      | "| " + _aws_to_cell(l["LayerName"]) +
                        " | " + _aws_to_cell(l["LayerArn"]) +
                        " | " + version +
                        " | " + runtimes + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

