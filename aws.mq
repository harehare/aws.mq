  def findings_above_severity(response, threshold):
    filter(findings(response), fn(f): f["Severity"] >= threshold;)
  end

  # Return high-severity findings (severity >= 7.0).
  def high_severity_findings(response):
    findings_above_severity(response, 7.0)
  end

  # Return medium-severity findings (4.0 <= severity < 7.0).
  def medium_severity_findings(response):
    filter(findings(response), fn(f): f["Severity"] >= 4.0 && f["Severity"] < 7.0;)
  end

  # Convert a GetFindings response to a Markdown table.
  def findings_to_markdown_table(response):
    let data = findings(response)
    | if (is_empty(data)):
        "No findings found."
      else:
        do
          let header = "| Id | Type | Severity | Title | Region |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(f):
                      "| " + _aws_to_cell(f["Id"]) +
                        " | " + _aws_to_cell(f["Type"]) +
