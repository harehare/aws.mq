module elbv2:
  # Extract load balancers from a DescribeLoadBalancers response.
  def load_balancers(response):
    if (is_none(response["LoadBalancers"])): [] else: response["LoadBalancers"]
  end

  # Filter load balancers with state code "active".
  def active_load_balancers(response):
    filter(load_balancers(response), fn(lb):
      !is_none(lb["State"]) && lb["State"]["Code"] == "active";
    )
  end

  # Filter load balancers by type ("application", "network", "gateway").
  def by_type(response, type):
    filter(load_balancers(response), fn(lb): lb["Type"] == type;)
  end

  # Get all load balancer names.
  def load_balancer_names(response):
    map(load_balancers(response), fn(lb): lb["LoadBalancerName"];)
  end

  # Convert a DescribeLoadBalancers response to a Markdown table.
  def load_balancers_to_markdown_table(response):
    let data = load_balancers(response)
    | if (is_empty(data)):
        "No load balancers found."
      else:
        do
          let header = "| Name | Type | Scheme | State | DNSName |"
          | let sep = "| --- | --- | --- | --- | --- |"
          | let rows = map(data, fn(lb):
                "| " + _aws_to_cell(lb["LoadBalancerName"]) +
                " | " + _aws_to_cell(lb["Type"]) +
                " | " + _aws_to_cell(lb["Scheme"]) +
                " | " + (if (is_none(lb["State"])): "" else: _aws_to_cell(lb["State"]["Code"])) +
                " | " + _aws_to_cell(lb["DNSName"]) + " |"
              end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract target groups from a DescribeTargetGroups response.
  def target_groups(response):
    if (is_none(response["TargetGroups"])): [] else: response["TargetGroups"]
  end

  # Get all target group names.
  def target_group_names(response):
    map(target_groups(response), fn(tg): tg["TargetGroupName"];)
  end

  # Convert a DescribeTargetGroups response to a Markdown table.
  def target_groups_to_markdown_table(response):
    let data = target_groups(response)
    | if (is_empty(data)):
        "No target groups found."
      else:
        do
          let header = "| TargetGroupName | Protocol | Port | TargetType |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(tg):
                "| " + _aws_to_cell(tg["TargetGroupName"]) +
                " | " + _aws_to_cell(tg["Protocol"]) +
                " | " + _aws_to_cell(tg["Port"]) +
                " | " + _aws_to_cell(tg["TargetType"]) + " |"
              end)
          | _aws_table(header, sep, rows)
        end
  end
end

module route53:
  # Extract hosted zones from a ListHostedZones response.
  def hosted_zones(response):
    if (is_none(response["HostedZones"])): [] else: response["HostedZones"]
  end

  # Get all hosted zone names.
  def zone_names(response):
    map(hosted_zones(response), fn(z): z["Name"];)
  end

  # Filter public hosted zones.
  def public_zones(response):
    filter(hosted_zones(response), fn(z):
      !is_none(z["Config"]) && z["Config"]["PrivateZone"] == false;
    )
  end

  # Filter private hosted zones.
  def private_zones(response):
    filter(hosted_zones(response), fn(z):
      !is_none(z["Config"]) && z["Config"]["PrivateZone"] == true;
    )
  end

  # Convert a ListHostedZones response to a Markdown table.
  def hosted_zones_to_markdown_table(response):
    let data = hosted_zones(response)
    | if (is_empty(data)):
        "No hosted zones found."
      else:
        do
          let header = "| Name | Id | Private | RecordSets |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(z):
                "| " + _aws_to_cell(z["Name"]) +
                " | " + _aws_to_cell(z["Id"]) +
                " | " + (if (is_none(z["Config"])): "" else: _aws_to_cell(z["Config"]["PrivateZone"])) +
                " | " + _aws_to_cell(z["ResourceRecordSetCount"]) + " |"
              end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract resource record sets from a ListResourceRecordSets response.
  def record_sets(response):
    if (is_none(response["ResourceRecordSets"])): [] else: response["ResourceRecordSets"]
  end

  # Filter record sets by DNS type (e.g. "A", "CNAME", "MX", "TXT").
  def by_record_type(response, type):
    filter(record_sets(response), fn(r): r["Type"] == type;)
  end

  # Convert a ListResourceRecordSets response to a Markdown table.
  def record_sets_to_markdown_table(response):
    let data = record_sets(response)
    | if (is_empty(data)):
        "No record sets found."
      else:
        do
          let header = "| Name | Type | TTL |"
          | let sep = "| --- | --- | --- |"
          | let rows = map(data, fn(r):
                "| " + _aws_to_cell(r["Name"]) +
                " | " + _aws_to_cell(r["Type"]) +
                " | " + _aws_to_cell(r["TTL"]) + " |"
              end)
          | _aws_table(header, sep, rows)
        end
  end
end
