  # Extract MFA devices from a ListMFADevices response.
  def mfa_devices(response):
    if (is_none(response["MFADevices"])): [] else: response["MFADevices"]
  end

  # Get all usernames that have MFA devices.
  def mfa_device_usernames(response):
