module athena:
  # Extract workgroups from a ListWorkGroups response.
  def workgroups(response):
    if (is_none(response["WorkGroups"])): [] else: response["WorkGroups"]
  end

  # Get all workgroup names.
  def workgroup_names(response):
    map(workgroups(response), fn(w): w["Name"];)
  end

  # Filter enabled workgroups.
  def enabled_workgroups(response):
    filter(workgroups(response), fn(w): w["State"] == "ENABLED";)
  end

  # Convert a ListWorkGroups response to a Markdown table.
  def workgroups_to_markdown_table(response):
    let data = workgroups(response)
    | if (is_empty(data)):
        "No workgroups found."
      else:
        do
          let header = "| Name | State | Description |"
          | let sep = "| --- | --- | --- |"
          | let rows = map(data, fn(w):
                      "| " + _aws_to_cell(w["Name"]) +
                        " | " + _aws_to_cell(w["State"]) +
                        " | " + _aws_to_cell(w["Description"]) + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end

  # Extract query executions from a BatchGetQueryExecution response.
  def query_executions(response):
    if (is_none(response["QueryExecutions"])): [] else: response["QueryExecutions"]
  end

  # Filter query executions by state (e.g. "SUCCEEDED", "FAILED", "RUNNING").
  def executions_by_state(response, state):
    filter(query_executions(response), fn(q):
      !is_none(q["Status"]) && q["Status"]["State"] == state;
    )
  end

  # Return succeeded query executions.
  def succeeded_executions(response):
    executions_by_state(response, "SUCCEEDED")
  end

  # Return failed query executions.
  def failed_executions(response):
    executions_by_state(response, "FAILED")
  end

  # Convert a BatchGetQueryExecution response to a Markdown table.
  def query_executions_to_markdown_table(response):
    let data = query_executions(response)
    | if (is_empty(data)):
        "No query executions found."
      else:
        do
          let header = "| QueryExecutionId | State | Workgroup | Database |"
          | let sep = "| --- | --- | --- | --- |"
          | let rows = map(data, fn(q):
                      let state = if (is_none(q["Status"])): "" else: _aws_to_cell(q["Status"]["State"])
                      | let db = if (is_none(q["QueryExecutionContext"]) || is_none(q["QueryExecutionContext"]["Database"])): "" else: _aws_to_cell(q["QueryExecutionContext"]["Database"])
                      | "| " + _aws_to_cell(q["QueryExecutionId"]) +
                        " | " + state +
                        " | " + _aws_to_cell(q["WorkGroup"]) +
                        " | " + db + " |"
                    end)
          | _aws_table(header, sep, rows)
        end
  end
end

